<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>57.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>
        Academic Multi-Page Application Intake Form
    </masterLabel>
    <description>
        A 50-question dynamic intake framework utilizing dynamic component factories,
        localized offline-caching, auto-saving logic and session state resume routines.
    </description>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__RecordPage</target>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <property
                name="cardTitle"
                type="String"
                label="Card Title"
                default="Academic Application Intake Portal" />
            <property
                name="iconName"
                type="String"
                label="Icon Name"
                default="standard:education" />
            <property
                name="submittedHeading"
                type="String"
                label="Submitted Heading"
                default="Application Submitted Successfully" />
            <property
                name="submitButtonLabel"
                type="String"
                label="Submit Button Label"
                default="Submit Application" />
            <property
                name="pageTitlesString"
                type="String"
                label="Page Titles JSON"
                default="" />
            <property
                name="excludedQuestionLabelsString"
                type="String"
                label="Excluded Question Labels"
                default="" />
            <property
                name="formConfigObjectApiName"
                type="String"
                label="Form Configuration Object API Name"
                default="Form_Configuration_c__mdt" />
            <objects>
                <object>Form_Submission__c</object>
            </objects>
        </targetConfig>
