<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>57.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>
        Academic Multi-Page Application Intake Form
    </masterLabel>
    <description>
        A 50-question dynamic intake framework utilizing dynamic component factories,
        localized offline-caching, auto-saving logic and session state resume routines.
    </description>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__RecordPage</target>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__HomePage,lightning__RecordPage">
            <property
                name="formConfigObjectApiName"
                type="String"
                label="Form Config Metadata Type"
                default="Form_Configuration_c__mdt" />
            <property
                name="cardTitle"
                type="String"
                label="Card Title"
                default="Academic Application Intake Portal" />
            <property
                name="iconName"
                type="String"
                label="Card Icon"
                default="standard:education" />
            <property
                name="submitButtonLabel"
                type="String"
                label="Submit Button Label"
                default="Submit Application" />
            <property
                name="submittedHeading"
                type="String"
                label="Submitted Heading"
                default="Application Submitted Successfully" />
            <property
                name="pageTitlesString"
                type="String"
                label="Page Titles"
                description="Optional pipe-separated page titles in page order." />
            <property
                name="excludedQuestionLabelsString"
                type="String"
                label="Excluded Question Labels"
                description="Optional pipe-separated question labels to hide from this form." />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
